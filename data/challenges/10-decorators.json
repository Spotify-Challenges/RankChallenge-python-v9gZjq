{"id":"10-decorators","level":5,"title":"Decorators","category":"python","categoryLabel":"Python","points":300,"description":"Fix decorator syntax.","objectives":["Use @decorator","*args, **kwargs"],"hints":["@timer"],"hintPenalty":40,"validationType":"python-output","files":[{"filename":"deco.py","language":"python","editable":true,"content":"import time\n\ndef timer(func):\n    def wrapper():\n        start = time.time()\n        result = func()\n        print(f\"Took {time.time()-start:.4f}s\")\n        return result\n    return wrapper\n\ntimer\ndef slow():\n    time.sleep(0.1)\n    return \"Done\"\n\nprint(slow())"}],"validation":{"checks":[{"description":"@timer","astRule":{"type":"contains-string","value":"@timer"},"points":35},{"description":"*args","astRule":{"type":"contains-string","value":"def wrapper(*args, **kwargs)"},"points":35},{"description":"pass args","astRule":{"type":"contains-string","value":"func(*args, **kwargs)"},"points":30}]},"unlockRequires":["09-comprehensions"]}
